# LedgerLens API — copy to `.env` and fill in values.

# LLM: stub | ollama | groq (Groq is fast cloud; Ollama remains available for local use)
LLM_PROVIDER=groq
# Get a free key at https://console.groq.com
GROQ_API_KEY=

# Web search (SerpAPI or Brave). Keys below are required when ENABLE_WEB_SEARCH=true.
WEB_SEARCH_API_KEY=
# serpapi | brave (optional; defaults to serpapi, or brave if key looks like Brave)
WEB_SEARCH_PROVIDER=
# Web search fires live on each query with the user's question.
# Set to true once GROQ is working — adds ~0.5s per query via Brave API.
ENABLE_WEB_SEARCH=true
